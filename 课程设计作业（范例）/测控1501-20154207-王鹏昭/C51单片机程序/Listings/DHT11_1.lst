  59   2          while(io && DHT_flag);    //吉棋方象佚催互窮峠Ą'0'葎26us-28usŁ'1'葎70us˘ 
  60   2          data_byte<<=1;//俊辺議方象葎互了壓念Ą嘔卞˘ 
  61   2          data_byte|=temp;
  62   2        } 
