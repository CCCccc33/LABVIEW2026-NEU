  66          //*************************************************************************
  67          bit DS18B20_Readbit()
  68          {
  69   1          bit res;
  70   1          DQ = 0;                       //开始时间片
  71   1          DelayXus(3);                  //延时等待
  72   1          DQ = 1;                       //准备接收
  73   1          DelayXus(3);                  //接收延时
  74   1          res=DQ;                       //读取数据
  75   1          DelayXus(120);                //等待时间片结束
  76   1          return res;
  77   1      }
  78          //*************************从DS18B20读1字节数据*****************************
  79          unsigned char DS18B20_ReadByte()
  80          {
  81   1          unsigned char i;
  82   1          unsigned char dat = 0;
  83   1      
  84   1          for (i=0; i<8; i++)
  85   1          {
  86   2              dat >>= 1;
  87   2              if (DS18B20_Readbit()) dat |= 0x80; //读取数据
  88   2          }
  89   1      
  90   1          return dat;
  91   1      }
  92          
  93          //*************************向DS18B20写1字节数据*****************************
  94          void DS18B20_WriteByte(unsigned char dat)
  95          {
  96   1          char i;
  97   1      
  98   1          for (i=0; i<8; i++)               //8位计数器
  99   1          {
 100   2              DQ = 0;                       //开始时间片
 101   2              DelayXus(3);                  //延时等待
 102   2              dat >>= 1;                    //送出数据
 103   2              DQ = CY;
 104   2              DelayXus(120);                //等待时间片结束
 105   2              DQ = 1;                       //恢复数据线
 106   2              DelayXus(3);                  //恢复延时
 107   2          }
 108   1      }
 109          //*************************读取指定ID的DS18B20的温度值************************
 110          unsigned int DS18B20_ReadDesignateTemper(unsigned char rom[8])  
 111          {  
 112   1          unsigned char th, tl;  
 113   1          unsigned int mdata;  
 114   1      //    read_seril();                       //读取总线上每个DS18B20的序列号，测试时使用
