 117   1          DS18B20_WriteByte(CONVERT_T);       //启动温度转换 指令
 118   1          DS18B20_Reset();  
 119   1          DS18B20_WriteByte(MATH_ROM);        //匹配ROM指令
 120   1          for(mdata = 0;mdata < 8;mdata ++)   //发送8个字节的序列号   
 121   1          {  
 122   2             DS18B20_WriteByte(rom[mdata]);  
 123   2          }  
 124   1          DelayXus(20);;  
 125   1          DS18B20_WriteByte(READ_SCRATCHPAD); //读取温度指令 
 126   1          tl = DS18B20_ReadByte();            //低8位数据
 127   1          th = DS18B20_ReadByte();            //高8位数据
 128   1          mdata = (th<<8) | tl;   
 129   1          
 130   1          return mdata;                       //返回值;  
