  38          //*************************延时X微秒(*2)********************************
  39          void DelayXus(unsigned char n)
  40          {
  41   1          while (n--)
  42   1          {
  43   2              _nop_();
  44   2              _nop_();
  45   2          }
  46   1      }
  47          
  48          //*************************复位DS18B20，返回0则设备存在*******************
  49          bit DS18B20_Reset()
  50          {
  51   1          bit result;
  52   1          DQ = 0;                       //送出低电平复位信号
  53   1          DelayXus(240);                //延时至少480us
  54   1          DelayXus(240);
